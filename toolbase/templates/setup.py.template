    #
    # token = ctx.prompt_secret("Enter your API token:")
    # ctx.set_config("api_token", token)

    # ── Download data ───────────────────────────────────────────
    # Resumable, SHA256-verified, auto-extract for tar/zip. Cache
    # lives under ~/.toolbase/cache/ — re-runs are fast.
    #
    # ctx.download(
    #     "https://example.com/data.tar.gz",
    #     destination=ctx.data_dir,
    #     extract=True,
    #     sha256="abc123...",  # optional but strongly recommended
    #     description="Reference data",
    #     size_hint="2.3 GB",
    # )
    # ctx.set_config("data_dir", str(ctx.data_dir))

    # ── Stash derived state ─────────────────────────────────────
    # Values written here reach @define_tool(state=[...]) without
    # needing to be declared in `config:`. Use this for things the
    # user shouldn't be prompted for — auto-detected hardware, paths
    # derived from other paths, etc.
    #
    # import subprocess
    # has_gpu = (
    #     subprocess.run(["nvidia-smi"], capture_output=True).returncode == 0
    # )
    # ctx.set_config("use_gpu", has_gpu)

    ctx.success("Setup complete.")
    return True


def validate(ctx):
    """Fast read-only check. Called at every `toolbase serve`
    startup; the result is cached against the config and setup.py
    mtimes so you only pay the spawn cost when something changed.

    Return True iff the toolkit is configured and ready to serve.
    Returning False causes serve to skip with the message you log
    via ctx.error/warn (or a generic "validate(ctx) returned False"
    if you log nothing).
